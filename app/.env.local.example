# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# AI — Groq (free tier, https://console.groq.com)
# Model: llama-3.3-70b-versatile
# To switch to Claude later: replace client in lib/ai/extract.ts
GROQ_API_KEY=your_groq_api_key

# Slack Integration (Phase 2.3)
# Bot Token: api.slack.com → your app → OAuth & Permissions → Bot User OAuth Token (xoxb-...)
SLACK_BOT_TOKEN=xoxb-your-bot-token
# Signing Secret: api.slack.com → your app → Basic Information → App Credentials → Signing Secret
SLACK_SIGNING_SECRET=your-signing-secret
